# Copy to .env and fill in. .env is gitignored and dockerignored — never commit.

# ── Access control ───────────────────────────────────────────────────────────
# password  = one shared gate password (simplest; no registration, no email)
# accounts  = per-person self-service login with verified email (needs email, see below)
AOS8_AUTH_MODE=password
# Required for password mode — the single password everyone uses to get in.
AOS8_APP_PASSWORD=change-me-to-a-strong-shared-password

# ── App credential persistence (optional) ────────────────────────────────────
# Fernet key enabling the encrypted "Remember". In password mode this is a
# single SHARED store (everyone with the password sees saved creds); leave blank
# to keep creds session-only. Generate:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AOS8_CREDSTORE_KEY=

# ── (accounts mode only) Account-verification email ──────────────────────────
# Only needed if AOS8_AUTH_MODE=accounts. Registration emails a 6-digit code.
# The From can be any sender (Gmail, throwaway, etc.). Pick one:
#
# (A) Gmail — easiest + reliable.
#     Enable 2FA, then create an App Password
#     (Google Account → Security → App passwords). From must equal the account.
# AOS8_SMTP_MODE=relay
# AOS8_SMTP_HOST=smtp.gmail.com
# AOS8_SMTP_PORT=587
# AOS8_SMTP_USER=youraccount@gmail.com
# AOS8_SMTP_PASS=your-16-char-app-password
# AOS8_SMTP_FROM=youraccount@gmail.com
#
# (B) Transactional provider (SendGrid/Resend/Brevo free tier) — same shape:
#     host smtp.sendgrid.net, user "apikey", pass <API key>, From your verified sender.
#
# (C) direct — no account at all; the app does the MX lookup and delivers itself.
#     May be spam-filtered from an unauthenticated IP. Set From to a domain you control:
# AOS8_SMTP_MODE=direct
# AOS8_SMTP_FROM=no-reply@some-domain-you-own
#
# With nothing set, codes are written to the container log (DEV ONLY).
AOS8_SMTP_MODE=
AOS8_SMTP_HOST=
AOS8_SMTP_PORT=587
AOS8_SMTP_USER=
AOS8_SMTP_PASS=
AOS8_SMTP_FROM=
