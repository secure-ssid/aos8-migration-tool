# Copy to .env and fill in. .env is gitignored and dockerignored — never commit.

# ── SSO / OIDC (oauth2-proxy) ────────────────────────────────────────────────
# From your IdP (Okta / Azure AD / Google / Keycloak / etc.) OIDC app:
OIDC_ISSUER_URL=https://your-idp.example.com/
OIDC_CLIENT_ID=your-oidc-client-id
OIDC_CLIENT_SECRET=your-oidc-client-secret
# Restrict who can sign in (use * to allow any verified email):
ALLOWED_EMAIL_DOMAIN=yourcompany.com
# Random 32-byte cookie secret. Generate:
#   python -c "import secrets,base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
COOKIE_SECRET=

# ── App credential persistence (optional) ────────────────────────────────────
# Fernet key enabling per-user encrypted "Remember". Leave blank to disable
# persistence (creds live only in each session). Generate:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AOS8_CREDSTORE_KEY=
