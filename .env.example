# Copy to .env and fill in. .env is gitignored and dockerignored — never commit.

# ── App credential persistence (optional) ────────────────────────────────────
# Fernet key enabling the per-user encrypted "Remember". Leave blank to disable
# persistence (creds live only in each session). Generate:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AOS8_CREDSTORE_KEY=

# ── SMTP for account-verification emails ─────────────────────────────────────
# Registration emails a 6-digit code to confirm the @hpe.com address is real.
# Without AOS8_SMTP_HOST the code is written to the container log (DEV ONLY) —
# set these for any real deployment (use your HPE internal relay).
AOS8_SMTP_HOST=
AOS8_SMTP_PORT=587
AOS8_SMTP_USER=
AOS8_SMTP_PASS=
AOS8_SMTP_FROM=no-reply@hpe.com
