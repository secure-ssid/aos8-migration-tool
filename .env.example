# Copy to .env and fill in. .env is gitignored and dockerignored — never commit.

# ── App credential persistence (optional) ────────────────────────────────────
# Fernet key enabling the per-user encrypted "Remember". Leave blank to disable
# persistence (creds live only in each session). Generate:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AOS8_CREDSTORE_KEY=

# ── Account-verification email ───────────────────────────────────────────────
# Registration emails a 6-digit code to confirm the @hpe.com address is real.
# Pick ONE delivery mode:
#
# (A) direct  — no relay needed; the app looks up the recipient domain's MX and
#     delivers itself. Simplest, but mail from an unsanctioned IP to a gateway
#     like Proofpoint (hpe.com) is usually rejected/spam-filtered. Reliable only
#     when the app's egress IP is an authorized sender for AOS8_SMTP_FROM.
# AOS8_SMTP_MODE=direct
# AOS8_SMTP_FROM=no-reply@hpe.com
#
# (B) relay   — hand off to an SMTP server (default mode). Works with a free
#     transactional provider (verified sender, good deliverability) or your own
#     mailbox via an app password. Example (SendGrid):
# AOS8_SMTP_MODE=relay
# AOS8_SMTP_HOST=smtp.sendgrid.net
# AOS8_SMTP_PORT=587
# AOS8_SMTP_USER=apikey
# AOS8_SMTP_PASS=SG.xxxxx
# AOS8_SMTP_FROM=no-reply@yourdomain
#
# With neither configured, codes are written to the container log (DEV ONLY).
AOS8_SMTP_MODE=
AOS8_SMTP_HOST=
AOS8_SMTP_PORT=587
AOS8_SMTP_USER=
AOS8_SMTP_PASS=
AOS8_SMTP_FROM=no-reply@hpe.com
