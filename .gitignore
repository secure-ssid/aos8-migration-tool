# ── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Streamlit ─────────────────────────────────────────────────────────────────
# Keep .streamlit/config.toml (theme/server config) but never commit secrets.
.streamlit/secrets.toml

# ── Deployment secrets ────────────────────────────────────────────────────────
# oauth2-proxy / OIDC + credstore key for docker-compose — never commit (.env.example is fine).
.env

# ── Tooling / local state ─────────────────────────────────────────────────────
.playwright-mcp/
*.log

# ── OS / editor cruft ─────────────────────────────────────────────────────────
.DS_Store
.idea/
.vscode/

# UI audit artifacts
audit-*.png
step*.png

# local TLS material from lab testing — never commit
aruba.crt
aruba.key
*.pem
*.key
